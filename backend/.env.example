# GitHub personal access token (optional for public repos, but raises rate limit from 60/hr to 5000/hr)
# Create one at: https://github.com/settings/tokens (no special scopes needed for public repos)
GITHUB_TOKEN=

# Gemini API key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Local development database. SQLite needs no installation.
DATABASE_URL=sqlite:///./issue_analyzer.db

# Later deployment option: switch only this value to PostgreSQL.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME

# Frontend origin allowed to call this API (for CORS)
FRONTEND_ORIGIN=http://localhost:5173
